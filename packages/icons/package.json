{
  "name": "@rn-ds/icons",
  "version": "0.0.0",
  "description": "Icons for rn-ds. Designer drops SVGs into svgs/, svgr codegens React Native components.",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/module/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "files": [
    "src",
    "lib",
    "svgs"
  ],
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "build": "npm run generate && bob build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf lib src/*.tsx src/index.ts",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-svg": ">=15"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@types/react": "^18.3.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-svg": "^15.8.0",
    "react-native-builder-bob": "^0.35.0",
    "typescript": "^5.7.0",
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      ["commonjs", { "esm": true }],
      ["module", { "esm": true }],
      ["typescript", { "esm": true }]
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
