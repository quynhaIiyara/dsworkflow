{
  "name": "@rn-ds/components",
  "version": "0.0.0",
  "description": "React Native components for rn-ds.",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/module/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "files": [
    "src",
    "lib"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet — TODO: jest + @testing-library/react-native' && exit 0",
    "clean": "rm -rf lib",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72"
  },
  "dependencies": {
    "@rn-ds/tokens": "*"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-builder-bob": "^0.35.0",
    "typescript": "^5.7.0",
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "**/*.{stories,test}.{ts,tsx}",
    "targets": [
      ["commonjs", { "esm": true }],
      ["module", { "esm": true }],
      ["typescript", { "esm": true }]
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
